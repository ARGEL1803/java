import javax.swing.*;
import java.awt.*;
import java.awt.event.*;
import java.util.Random;

public class Juego extends JPanel implements KeyListener, ActionListener {

    private Jugador jugador;
    private NPC[] npcs;
    private Balon balon;
    private Timer timer;

    private boolean juegoTerminado = false;
    private int golesJugador = 0;
    private int golesNPC = 0;

    private final int ancho = 800;
    private final int alto = 600;

    private Rectangle porteriaIzq = new Rectangle(50, alto/2 - 60, 30, 120);
    private Rectangle porteriaDer = new Rectangle(ancho - 80, alto/2 - 60, 30, 120);

    public Juego() {
        setPreferredSize(new Dimension(ancho, alto));
        setBackground(new Color(34, 139, 34));

        jugador = new Jugador(100, alto/2);
        balon = new Balon(ancho/2, alto/2);

        npcs = new NPC[4];
        Random rand = new Random();
        for (int i = 0; i < npcs.length; i++) {
            int x = rand.nextInt(ancho - 160) + 100;
            int y = rand.nextInt(alto - 160) + 100;
            npcs[i] = new NPC(x, y);
        }

        timer = new Timer(40, this);
        timer.start();

        setFocusable(true);
        addKeyListener(this);
    }

    @Override
    protected void paintComponent(Graphics g) {
        super.paintComponent(g);

        g.setColor(new Color(0, 100, 0));
        g.fillRect(50, 50, ancho - 100, alto - 100);

        g.setColor(Color.WHITE);
        g.drawRect(50, 50, ancho - 100, alto - 100);
        g.drawLine(ancho / 2, 50, ancho / 2, alto - 50);
        g.drawOval(ancho / 2 - 75, alto / 2 - 75, 150, 150);

        g.fillRect(porteriaIzq.x, porteriaIzq.y, porteriaIzq.width, porteriaIzq.height);
        g.fillRect(porteriaDer.x, porteriaDer.y, porteriaDer.width, porteriaDer.height);

        jugador.dibujar(g);
        for (NPC npc : npcs) {
            npc.dibujar(g);
        }
        balon.dibujar(g);

        g.setColor(Color.WHITE);
        g.drawString("Coordenadas Jugador: (" + jugador.x + ", " + jugador.y + ")", 10, 20);
        g.drawString("Goles Jugador: " + golesJugador + "   Goles NPC: " + golesNPC, 10, 40);

        if (juegoTerminado) {
            g.setFont(new Font("Arial", Font.BOLD, 48));
            g.setColor(Color.YELLOW);
            String msg = (golesJugador > golesNPC) ? "¡Ganaste!" : "¡Perdiste!";
            g.drawString(msg, ancho / 2 - 150, alto / 2);
            timer.stop();
        }
    }

    @Override
    public void keyPressed(KeyEvent e) {
        if (juegoTerminado) return;

        int key = e.getKeyCode();
        int dx = 0, dy = 0;

        if (key == KeyEvent.VK_W) dy = -10;
        if (key == KeyEvent.VK_S) dy = 10;
        if (key == KeyEvent.VK_A) dx = -10;
        if (key == KeyEvent.VK_D) dx = 10;

        jugador.mover(dx, dy, ancho, alto);
        repaint();
    }

    @Override
    public void keyReleased(KeyEvent e) {}
    @Override
    public void keyTyped(KeyEvent e) {}

    @Override
    public void actionPerformed(ActionEvent e) {
        if (juegoTerminado) return;

        for (NPC npc : npcs) {
            npc.moverHacia(balon, ancho, alto);
        }

        if (colision(jugador, balon)) {
            balon.x = jugador.x + jugador.size/2 - balon.size/2;
            balon.y = jugador.y + jugador.size/2 - balon.size/2;
        }

        if (balon.x < porteriaIzq.x + porteriaIzq.width &&
            balon.y + balon.size > porteriaIzq.y &&
            balon.y < porteriaIzq.y + porteriaIzq.height) {
            golesNPC++;
            reiniciarPosiciones();
        }

        if (balon.x + balon.size > porteriaDer.x &&
            balon.y + balon.size > porteriaDer.y &&
            balon.y < porteriaDer.y + porteriaDer.height) {
            golesJugador++;
            reiniciarPosiciones();
        }

        for (NPC npc : npcs) {
            if (colision(npc, balon)) {
                int dx = (npc.x < balon.x) ? 3 : -3;
                int dy = (npc.y < balon.y) ? 3 : -3;
                moverBalon(dx, dy);
            }
        }

        if (golesJugador >= 5 || golesNPC >= 5) {
            juegoTerminado = true;
        }

        repaint();
    }

    private boolean colision(Entidad a, Entidad b) {
        Rectangle r1 = new Rectangle(a.x, a.y, a.size, a.size);
        Rectangle r2 = new Rectangle(b.x, b.y, b.size, b.size);
        return r1.intersects(r2);
    }

    private void moverBalon(int dx, int dy) {
        int nx = balon.x + dx;
        int ny = balon.y + dy;
        if (nx >= 60 && nx <= ancho - 100) balon.x = nx;
        if (ny >= 60 && ny <= alto - 100) balon.y = ny;
    }

    private void reiniciarPosiciones() {
        jugador.x = 100;
        jugador.y = alto / 2;
        balon.x = ancho / 2;
        balon.y = alto / 2;

        Random rand = new Random();
        for (NPC npc : npcs) {
            npc.x = rand.nextInt(ancho - 160) + 100;
            npc.y = rand.nextInt(alto - 160) + 100;
        }
    }

    public static void main(String[] args) {
        JFrame frame = new JFrame("Juego de Fútbol Simple");
        Juego juego = new Juego();
        frame.setDefaultCloseOperation(JFrame.EXIT_ON_CLOSE);
        frame.setResizable(false);
        frame.add(juego);
        frame.pack();
        frame.setLocationRelativeTo(null);
        frame.setVisible(true);
    }
}
